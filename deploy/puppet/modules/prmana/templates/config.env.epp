<%- |
  String $issuer,
  String $client_id,
  Boolean $enable_dpop,
| -%>
# prmana configuration
# Managed by Puppet - DO NOT EDIT MANUALLY

# OIDC Issuer URL (required)
PRMANA_ISSUER=<%= $issuer %>

# OIDC Client ID
PRMANA_CLIENT_ID=<%= $client_id %>

# Enable DPoP (Demonstration of Proof-of-Possession)
PRMANA_ENABLE_DPOP=<%= $enable_dpop %>
